<mujoco model="wheeled_ur5e_with_wheels">
  <compiler angle="radian"/>

  <option integrator="implicitfast"/>

  <visual>
    <global azimuth="120" elevation="-20"/>
    <headlight ambient="0.3 0.3 0.3" diffuse="0.6 0.6 0.6" specular="0 0 0"/>
    <map force="0.1" zfar="30"/>
    <rgba haze="0.15 0.25 0.35 1"/>
  </visual>

  <default>
    <joint limited="true"/>
    <geom solref="0.008"/>
    <general ctrllimited="true"/>
  </default>

  <asset>
    <texture type="skybox" colorspace="auto" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" colorspace="auto" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
    <light pos="0 0 3.5" dir="0 0 -1" type="directional" diffuse="0.4 0.4 0.4" specular="0.1 0.1 0.1"/>
    <light pos="1.5 1.5 2.5" dir="-0.485071 -0.485071 -0.727607" diffuse="0.5 0.5 0.5"/>
    <body name="base_x_body">
      <inertial pos="0 0 0" mass="0.1" diaginertia="0.01 0.01 0.01"/>
      <joint name="base_x" pos="0 0 0" axis="1 0 0" type="slide" range="-5 5"/>
      <body name="base_y_body">
        <inertial pos="0 0 0" mass="0.1" diaginertia="0.01 0.01 0.01"/>
        <joint name="base_y" pos="0 0 0" axis="0 1 0" type="slide" range="-5 5"/>
        <body name="base_yaw_body">
          <inertial pos="0 0 0" mass="0.1" diaginertia="0.01 0.01 0.01"/>
          <joint name="base_yaw" pos="0 0 0" axis="0 0 1" range="-6.2832 6.2832"/>
          <body name="base_z_body">
            <inertial pos="0 0 0" mass="0.1" diaginertia="0.01 0.01 0.01"/>
            <joint name="base_z" pos="0 0 0" axis="0 0 1" type="slide" range="0 0.5"/>
            <body name="chassis" pos="0 0 0.14">
              <inertial pos="0 0 0" mass="30" diaginertia="1 1 0.5"/>
              <geom size="0.35 0.25 0.05" type="box" rgba="0.2 0.2 0.7 1"/>
              <body name="left_wheel_body" pos="0 0.25 -0.04">
                <inertial pos="0 0 0" mass="2" diaginertia="0.01 0.01 0.01"/>
                <joint name="left_wheel_joint" pos="0 0 0" axis="0 1 0" range="-100 100" armature="0.01" damping="0.1"/>
                <geom size="0.1 0.04" quat="0.707105 0.707108 0 0" type="cylinder" rgba="0.1 0.1 0.1 1"/>
              </body>
              <body name="right_wheel_body" pos="0 -0.25 -0.04">
                <inertial pos="0 0 0" mass="2" diaginertia="0.01 0.01 0.01"/>
                <joint name="right_wheel_joint" pos="0 0 0" axis="0 1 0" range="-100 100" armature="0.01" damping="0.1"/>
                <geom size="0.1 0.04" quat="0.707105 0.707108 0 0" type="cylinder" rgba="0.1 0.1 0.1 1"/>
              </body>
              <body name="shoulder_link" pos="0 0 0.27">
                <inertial pos="0 0 0" mass="3.761" diaginertia="0.01 0.01 0.01"/>
                <joint name="shoulder_pan_joint" pos="0 0 0" axis="0 0 1" range="-6.2832 6.2832" armature="0.1" damping="1"/>
                <geom size="0.06 0.06" type="cylinder" rgba="0.3 0.3 0.8 1"/>
                <geom size="0.055 0.02" pos="0 0 0.02" quat="0 1 0 0" type="capsule" rgba="0.3 0.3 0.8 1"/>
                <geom size="0.05 0.0679" pos="0 0.0679 0" quat="0.707107 0.707107 0 0" type="capsule" rgba="0.3 0.3 0.8 1"/>
                <body name="upper_arm_link" pos="0 0.1358 0">
                  <inertial pos="-0.2125 0 0" mass="8.058" diaginertia="0.2 0.2 0.01"/>
                  <joint name="shoulder_lift_joint" pos="0 0 0" axis="0 1 0" range="-6.2832 6.2832" armature="0.1" damping="1"/>
                  <geom size="0.04 0.2125" pos="-0.2125 0 0" quat="0.707107 0 0.707107 0" type="capsule" rgba="0.3 0.5 0.8 1"/>
                  <body name="forearm_link" pos="-0.425 0 0">
                    <inertial pos="-0.1961 0 0.067" mass="2.846" diaginertia="0.05 0.05 0.01"/>
                    <joint name="elbow_joint" pos="0 0 0" axis="0 1 0" range="-3.1416 3.1416" armature="0.1" damping="0.5"/>
                    <geom size="0.035 0.1961" pos="-0.1961 0 0" quat="0.707107 0 0.707107 0" type="capsule" rgba="0.3 0.6 0.7 1"/>
                    <geom size="0.033 0.06665" pos="-0.3922 0 0.06665" quat="0 1 0 0" type="capsule" rgba="0.3 0.6 0.7 1"/>
                    <body name="wrist_1_link" pos="-0.3922 0 0.1333">
                      <inertial pos="0 -0.05 0" mass="1.37" diaginertia="0.005 0.005 0.005"/>
                      <joint name="wrist_1_joint" pos="0 0 0" axis="0 1 0" range="-6.2832 6.2832" armature="0.01" damping="0.1"/>
                      <geom size="0.032 0.035" type="cylinder"/>
                      <geom size="0.031 0.04985" pos="0 -0.04985 0" quat="0.707107 -0.707107 0 0" type="capsule"/>
                      <body name="wrist_2_link" pos="0 -0.0997 0">
                        <inertial pos="0 0 0.05" mass="1.37" diaginertia="0.005 0.005 0.005"/>
                        <joint name="wrist_2_joint" pos="0 0 0" axis="0 0 1" range="-6.2832 6.2832" armature="0.01" damping="0.1"/>
                        <geom size="0.032 0.035" type="cylinder"/>
                        <geom size="0.031 0.0498" pos="0 0 0.0498" quat="0 1 0 0" type="capsule"/>
                        <body name="wrist_3_link" pos="0 0 0.0996">
                          <inertial pos="0 -0.05 0" mass="0.195" diaginertia="0.001 0.001 0.001"/>
                          <joint name="wrist_3_joint" pos="0 0 0" axis="0 1 0" range="-6.2832 6.2832" armature="0.01" damping="0.1"/>
                          <geom size="0.03 0.02" type="cylinder" rgba="0.6 0.6 0.6 1"/>
                          <site name="ee_site" pos="0 -0.0996 0" size="0.02" rgba="1 0 0 1"/>
                        </body>
                      </body>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <general name="act_base_x" joint="base_x" ctrlrange="-1 1" biastype="affine" gainprm="100" biasprm="0 0 -100"/>
    <general name="act_base_y" joint="base_y" ctrlrange="-1 1" biastype="affine" gainprm="100" biasprm="0 0 -100"/>
    <general name="act_base_z" joint="base_z" ctrlrange="-0.5 0.5" biastype="affine" gainprm="100" biasprm="0 0 -100"/>
    <general name="act_base_yaw" joint="base_yaw" ctrlrange="-3.14 3.14" biastype="affine" gainprm="50" biasprm="0 0 -50"/>
    <general name="act_left_wheel" joint="left_wheel_joint" ctrlrange="-10 10" gear="50 0 0 0 0 0"/>
    <general name="act_right_wheel" joint="right_wheel_joint" ctrlrange="-10 10" gear="50 0 0 0 0 0"/>
    <general name="act_shoulder_pan" joint="shoulder_pan_joint" ctrlrange="-150 150"/>
    <general name="act_shoulder_lift" joint="shoulder_lift_joint" ctrlrange="-150 150"/>
    <general name="act_elbow" joint="elbow_joint" ctrlrange="-150 150"/>
    <general name="act_wrist_1" joint="wrist_1_joint" ctrlrange="-28 28"/>
    <general name="act_wrist_2" joint="wrist_2_joint" ctrlrange="-28 28"/>
    <general name="act_wrist_3" joint="wrist_3_joint" ctrlrange="-28 28"/>
  </actuator>
</mujoco>
